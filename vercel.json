{
  "buildCommand": "vite build",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://raw.githubusercontent.com/ardrotterdam/safe-grip/main/public/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://raw.githubusercontent.com/ardrotterdam/safe-grip/main/public/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}
