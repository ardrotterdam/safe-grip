{
  "buildCommand": "vite build && cp -r public/sitemap.xml dist/ && cp -r public/robots.txt dist/",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.safe-grip.eu"
        }
      ],
      "destination": "https://safe-grip.eu/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
