{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.safe-grip.eu"
        }
      ],
      "destination": "https://safe-grip.eu/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|_next|sitemap.xml|robots.txt|favicon.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
